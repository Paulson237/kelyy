# --- LLM (required) ---
# cognee uses LLM_API_KEY; OPENAI_API_KEY is mirrored into it automatically by config.py.
LLM_API_KEY=sk-...
# Optional: override the model (default openai/gpt-4o-mini; cognee's own default is gpt-5-mini).
# LLM_MODEL=openai/gpt-4o-mini
# Model used by our LLM-as-judge + linter (default gpt-4o-mini).
# KELY_JUDGE_MODEL=gpt-4o-mini

# --- Cognee Cloud (optional, rewarded "Best use of Cognee Cloud") ---
# Set both to run the whole brain (session + permanent tiers) inside a managed instance.
# COGNEE_SERVICE_URL=https://your-instance.cognee.ai
# COGNEE_API_KEY=ck_...

# --- App ---
# KELY_DATASET=angelsitting
